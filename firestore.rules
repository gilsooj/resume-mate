rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
      
      match /resumes/{resumeId} {
        allow read, write: if true;
      }
    }

    match /resumes/{resumeId} {
      allow read: if true;
      allow create: if true;
    }
  }
}
